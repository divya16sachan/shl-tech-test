{
  "name": "SHL Assessment Copilot API",
  "description": "Simple AI assistant API for recommending SHL assessments through chat.",
  "baseUrl": "https://shl-tech-test.onrender.com",
  "frontend": "https://shl-tech-test.vercel.app",
  "contentType": "application/json",

  "routes": {
    "GET /health": {
      "description": "Check if the API server is running.",
      "response": {
        "status": "ok"
      }
    },

    "POST /chat": {
      "description": "Send a message to the AI assistant and receive streamed responses in real time.",
      "contentType": "text/event-stream",

      "requestBody": {
        "conversationId": "optional conversation ID",
        "messages": [
          {
            "role": "user",
            "content": "Recommend assessments for a Java developer"
          }
        ],
        "model": "optional AI model"
      },

      "events": {
        "status": {
          "description": "Shows current processing step.",
          "values": [
            "thinking",
            "retrieving",
            "reading",
            "generating",
            "done"
          ]
        },

        "text": {
          "description": "AI response text chunk."
        },

        "recommendations": {
          "description": "Recommended assessments list."
        },

        "conversationId": {
          "description": "Conversation ID for continuing the chat later."
        },

        "error": {
          "description": "Returned if something goes wrong."
        }
      }
    },

    "GET /conversations": {
      "description": "Get all saved conversations."
    },

    "GET /conversations/:id": {
      "description": "Get a specific conversation."
    },

    "GET /conversations/:id/messages": {
      "description": "Get all messages from a conversation."
    },

    "PATCH /conversations/:id": {
      "description": "Rename a conversation.",
      "requestBody": {
        "title": "New conversation title"
      }
    },

    "DELETE /conversations/:id": {
      "description": "Delete a conversation and its messages."
    },

    "GET /eval": {
      "description": "Run a live AI evaluation stream."
    },

    "POST /eval/run": {
      "description": "Run and save a full evaluation."
    },

    "GET /eval/runs": {
      "description": "Get all previous evaluation runs."
    },

    "GET /eval/runs/latest": {
      "description": "Get the latest evaluation report."
    },

    "GET /eval/runs/:id": {
      "description": "Get a specific evaluation result."
    }
  },

  "exampleChatRequest": {
    "url": "https://shl-tech-test.onrender.com/chat",
    "method": "POST",
    "body": {
      "messages": [
        {
          "role": "user",
          "content": "Recommend assessments for a frontend React developer"
        }
      ]
    }
  }
}