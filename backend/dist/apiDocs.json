{
    "name": "SHL Assessment Copilot API",
    "version": "1.0.0",
    "description": "A RAG-powered assistant that recommends SHL Individual Test Solutions via conversational AI. Uses Qdrant vector search for retrieval, Groq (LLaMA-3.3-70B) for generation, and streams responses over Server-Sent Events (SSE).",
    "baseUrl": "https://shl-tech-test.onrender.com",
    "contentType": "application/json (except /chat which uses text/event-stream)",
    "links": {
        "💻 frontend": "https://shl-tech-test.vercel.app",
        "🟢 api": "https://shl-tech-test.onrender.com"
    },
    "routes": {
        "GET /health": {
            "url": "https://shl-tech-test.onrender.com/health",
            "description": "Liveness probe. Returns HTTP 200 when the server is up.",
            "parameters": null,
            "requestBody": null,
            "response": {
                "status": "ok"
            },
            "errors": {}
        },
        "POST /chat": {
            "url": "https://shl-tech-test.onrender.com/chat",
            "description": "Accepts a conversation turn and streams the assistant reply as Server-Sent Events. Internally: classifies intent → vector-searches Qdrant → builds a grounded prompt → streams the LLM reply → emits structured recommendation data → persists to MongoDB.",
            "contentType": "text/event-stream",
            "requestBody": {
                "schema": {
                    "conversationId": {
                        "type": "string | undefined",
                        "description": "MongoDB ObjectId of an existing conversation. Omit (or send null) to start a new one.",
                        "required": false,
                        "example": "6645f3a2e4b0c12d3f9a0001"
                    },
                    "messages": {
                        "type": "Array<{ role: \"user\" | \"assistant\"; content: string }>",
                        "description": "Full message history sent to the LLM for context. The last element must be the current user message.",
                        "required": true,
                        "example": [
                            {
                                "role": "user",
                                "content": "Recommend assessments for a senior Java developer"
                            }
                        ]
                    },
                    "model": {
                        "type": "string",
                        "description": "Groq model identifier to use for generation.",
                        "required": false,
                        "default": "llama-3.3-70b-versatile",
                        "example": "llama-3.3-70b-versatile"
                    }
                }
            },
            "sseEventStream": {
                "description": "Each SSE message is a JSON object prefixed with \"data: \". The stream ends with \"data: [DONE]\".",
                "events": {
                    "status": {
                        "shape": "{ type: \"status\"; status: StatusEvent; detail?: string }",
                        "description": "Pipeline progress updates emitted at each processing stage.",
                        "statusValues": {
                            "thinking": "Intent classification in progress.",
                            "retrieving": "Qdrant vector search running.",
                            "reading": "Retrieved assessment payloads being parsed.",
                            "generating": "LLM token stream started.",
                            "done": "All processing complete. Stream is about to close."
                        }
                    },
                    "intent": {
                        "shape": "{ type: \"intent\"; intent: Intent }",
                        "description": "Resolved intent label for the current turn.",
                        "intentValues": {
                            "clarify": "Request is too vague — assistant will ask a follow-up question.",
                            "recommend": "Enough context to recommend assessments.",
                            "compare": "User wants a side-by-side comparison of specific assessments.",
                            "refine": "User is narrowing or adjusting a previous shortlist.",
                            "off_topic": "Request is unrelated to SHL assessments."
                        }
                    },
                    "retrieved_count": {
                        "shape": "{ type: \"retrieved_count\"; count: number; detail: string }",
                        "description": "Number of assessments returned from the vector search."
                    },
                    "text": {
                        "shape": "{ type: \"text\"; content: string }",
                        "description": "Streamed LLM token fragment. Concatenate all content values to reconstruct the full reply."
                    },
                    "recommendations": {
                        "shape": "{ type: \"recommendations\"; content: SHLAssessment[] }",
                        "description": "Structured recommendation payload emitted once after the full text stream. Contains the raw Qdrant results used to ground the reply."
                    },
                    "conversationId": {
                        "shape": "{ type: \"conversationId\"; content: string }",
                        "description": "MongoDB ObjectId of the conversation (new or existing). Persist this to resume the thread."
                    },
                    "end_of_conversation": {
                        "shape": "{ type: \"end_of_conversation\"; value: boolean }",
                        "description": "True when the intent is \"off_topic\" — the frontend may use this to show a session-end indicator."
                    },
                    "error": {
                        "shape": "{ type: \"error\"; content: string }",
                        "description": "Emitted on unhandled server errors. Stream ends immediately after."
                    }
                }
            },
            "typeDefinitions": {
                "Intent": "\"clarify\" | \"recommend\" | \"compare\" | \"refine\" | \"off_topic\"",
                "StatusEvent": "\"thinking\" | \"retrieving\" | \"reading\" | \"generating\" | \"done\"",
                "SHLAssessment": {
                    "name": "string   // assessment display name",
                    "url": "string   // canonical SHL product URL",
                    "remote_testing": "boolean  // supports remote administration",
                    "adaptive_irt": "boolean  // uses adaptive Item Response Theory",
                    "test_types": "any[]    // raw test-type objects from catalog",
                    "test_type_codes": "string   // comma-separated short codes, e.g. \"A, B, K\"",
                    "description": "string   // full assessment description used in vector index"
                },
                "IEvalSummary": {
                    "meanRecall": "number   // average Recall@10 of non-vague intents",
                    "groundedness": "number   // percentage of grounded traces",
                    "probePassRate": "number   // multi-point intent logic probe pass rate",
                    "avgTurns": "number   // average turns utilized",
                    "totalTraces": "number",
                    "passedTraces": "number"
                },
                "IEvalTrace": {
                    "id": "string   // short tracer ID",
                    "title": "string   // name of the test query",
                    "query": "string   // raw prompt",
                    "persona": "string   // tester persona description",
                    "isVague": "boolean",
                    "isOffTopic": "boolean",
                    "expectedAssessments": "string[] // canonical names required to pass recall",
                    "retrieved": "string[] // assessment names returned from retrieval",
                    "recall": "number   // computed Recall@10",
                    "grounded": "boolean  // groundedness assessment",
                    "intent": "Intent   // actual model-classified intent",
                    "probes": {
                        "clarified": "boolean",
                        "refused": "boolean",
                        "refined": "boolean",
                        "turnCap": "boolean"
                    },
                    "note": "string   // evaluation reasoning/diagnostic log"
                }
            }
        },
        "GET /conversations": {
            "url": "https://shl-tech-test.onrender.com/conversations",
            "description": "Lists all conversations, sorted by most recently updated.",
            "parameters": null,
            "response": {
                "type": "Conversation[]",
                "shape": {
                    "_id": "string   // MongoDB ObjectId",
                    "title": "string   // auto-generated or user-renamed title",
                    "memorySummary": "string   // JSON-serialised MemorySummary object",
                    "createdAt": "string   // ISO 8601 timestamp",
                    "updatedAt": "string   // ISO 8601 timestamp"
                }
            },
            "errors": {
                "500": "{ error: \"Failed to fetch conversations\" }"
            }
        },
        "GET /conversations/:id": {
            "url": "https://shl-tech-test.onrender.com/conversations/:id",
            "description": "Fetches a single conversation by its MongoDB ObjectId.",
            "parameters": {
                "id": {
                    "in": "path",
                    "type": "string",
                    "required": true,
                    "description": "MongoDB ObjectId."
                }
            },
            "response": {
                "type": "Conversation",
                "shape": {
                    "_id": "string",
                    "title": "string",
                    "memorySummary": "string   // JSON: { role, seniority, technical_skills, behavioral_requirements, personality_requirements, preferences, constraints }",
                    "createdAt": "string",
                    "updatedAt": "string"
                }
            },
            "errors": {
                "404": "{ error: \"Not found\" }",
                "500": "{ error: \"Failed to fetch conversation\" }"
            }
        },
        "GET /conversations/:id/messages": {
            "url": "https://shl-tech-test.onrender.com/conversations/:id/messages",
            "description": "Returns all messages for a conversation, sorted oldest-first.",
            "parameters": {
                "id": {
                    "in": "path",
                    "type": "string",
                    "required": true,
                    "description": "Conversation ObjectId."
                }
            },
            "response": {
                "type": "Message[]",
                "shape": {
                    "_id": "string",
                    "conversationId": "string   // reference to parent Conversation",
                    "role": "\"user\" | \"assistant\" | \"system\"",
                    "content": "string",
                    "recommendations": "SHLAssessment[]   // populated only on assistant messages that returned results",
                    "model": "string | undefined   // Groq model used for this reply",
                    "createdAt": "string"
                }
            },
            "errors": {
                "500": "{ error: \"Failed to fetch messages\" }"
            }
        },
        "PATCH /conversations/:id": {
            "url": "https://shl-tech-test.onrender.com/conversations/:id",
            "description": "Renames a conversation.",
            "parameters": {
                "id": {
                    "in": "path",
                    "type": "string",
                    "required": true
                }
            },
            "requestBody": {
                "schema": {
                    "title": {
                        "type": "string",
                        "required": true,
                        "description": "New conversation title."
                    }
                }
            },
            "response": {
                "type": "Conversation",
                "description": "Updated conversation document."
            },
            "errors": {
                "500": "{ error: \"Failed to rename conversation\" }"
            }
        },
        "DELETE /conversations/:id": {
            "url": "https://shl-tech-test.onrender.com/conversations/:id",
            "description": "Deletes a conversation and all its associated messages.",
            "parameters": {
                "id": {
                    "in": "path",
                    "type": "string",
                    "required": true
                }
            },
            "response": {
                "success": "true"
            },
            "errors": {
                "500": "{ error: \"Failed to delete conversation\" }"
            }
        },
        "GET /eval": {
            "url": "https://shl-tech-test.onrender.com/eval",
            "description": "Server-Sent Events (SSE) endpoint that streams the execution of the 8 evaluation probes in real-time, executing vector queries and intent classification live.",
            "contentType": "text/event-stream",
            "parameters": null,
            "response": {
                "description": "Streams real-time trace events. Does not persist results.",
                "events": {
                    "eval_start": { "shape": "{ type: \"eval_start\", total: number, detail: string }" },
                    "trace_start": { "shape": "{ type: \"trace_start\", id: string, title: string, persona: string, detail: string }" },
                    "trace_status": { "shape": "{ type: \"trace_status\", id: string, status: string, detail: string }" },
                    "trace_complete": { "shape": "{ type: \"trace_complete\", id: string, trace: IEvalTrace }" },
                    "eval_complete": { "shape": "{ type: \"eval_complete\", summary: IEvalSummary, totalDurationMs: number }" }
                }
            },
            "errors": {
                "500": "{ error: \"Evaluation failed\" }"
            }
        },
        "POST /eval/run": {
            "url": "https://shl-tech-test.onrender.com/eval/run",
            "description": "Triggers a full synchronous evaluation run, calculates overall performance metrics, persists the run details in MongoDB, and returns the persisted document.",
            "parameters": null,
            "response": {
                "type": "EvalRun",
                "shape": {
                    "_id": "string",
                    "runAt": "string",
                    "summary": "IEvalSummary",
                    "traces": "IEvalTrace[]",
                    "durationMs": "number"
                }
            },
            "errors": {
                "500": "{ error: \"Evaluation failed\" }"
            }
        },
        "GET /eval/runs": {
            "url": "https://shl-tech-test.onrender.com/eval/runs",
            "description": "Lists all past evaluation runs sorted newest-first. Uses MongoDB projection to exclude the heavy `traces` array to minimize payloads.",
            "parameters": null,
            "response": {
                "type": "Array<{ _id: string, runAt: string, summary: IEvalSummary, durationMs: number }>"
            },
            "errors": {
                "500": "{ error: \"Failed to list runs\" }"
            }
        },
        "GET /eval/runs/latest": {
            "url": "https://shl-tech-test.onrender.com/eval/runs/latest",
            "description": "Fetches the full details of the absolute latest historical evaluation run.",
            "parameters": null,
            "response": {
                "type": "EvalRun"
            },
            "errors": {
                "404": "{ error: \"No evaluation runs found\" }",
                "500": "{ error: \"Failed to fetch latest run\" }"
            }
        },
        "GET /eval/runs/:id": {
            "url": "https://shl-tech-test.onrender.com/eval/runs/:id",
            "description": "Fetches a specific historical evaluation run by its ObjectId.",
            "parameters": {
                "id": {
                    "in": "path",
                    "type": "string",
                    "required": true,
                    "description": "ObjectId of the EvalRun document."
                }
            },
            "response": {
                "type": "EvalRun"
            },
            "errors": {
                "404": "{ error: \"Evaluation run not found\" }",
                "500": "{ error: \"Failed to fetch run\" }"
            }
        }
    }
}
